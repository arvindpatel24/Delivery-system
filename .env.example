DATABASE_URL=postgres://samagri:samagri@localhost:5432/samagri_delivery
DATABASE_MAX_CONNECTIONS=10
LOCATION_POOL_MAX_CONNECTIONS=5

JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24

AUTH_MODE=real
# Set AUTH_MODE=mock to bypass authentication

RATE_LIMIT_SHOP_PER_MINUTE=100
RATE_LIMIT_DRIVER_PER_SECOND=10

WEBHOOK_TIMEOUT_SECS=5
WEBHOOK_MAX_RETRIES=5

BATCH_SCHEDULE_HOURS=13,20
BATCH_CLUSTER_EPS_METERS=1500
BATCH_MAX_ORDERS_PER_CLUSTER=10

INSTANT_DISPATCH_RADIUS_METERS=2000
INSTANT_DISPATCH_TIMEOUT_SECS=90

RUST_LOG=info,delivery_api=debug,delivery_infrastructure=debug

HOST=0.0.0.0
PORT=8080
